// M1 schema: users + sessions only. M2 introduces scenarios, artifacts,
// questions, attempts, etc. — keep this file tight for now.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  instructor
  trainee
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.Citext
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         Role
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  sessions Session[]

  @@map("users")
}

// Sessions store only a SHA-256 hash of the token. The raw token is
// returned to the client once at login and never persisted.
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ip        String?
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}
