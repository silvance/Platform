// M1 schema: users + sessions.
// M2 schema: + scenarios, scenario_briefs.
// M3+ will add artifacts, questions, attempts, etc.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  instructor
  trainee
}

// Keep in sync with SkillArea in packages/contracts/src/scenarios.ts.
enum SkillArea {
  email_headers
  bec
  df_artifacts
  removable_media
  windows_artifacts
  network_logs
  account_compromise
  rf_awareness
  report_writing
  inference_discipline
}

enum ScenarioStatus {
  draft
  published
  archived
}

enum ScenarioSource {
  authored
  imported
}

// Keep in sync with ArtifactKind in packages/contracts/src/scenarios.ts.
enum ArtifactKind {
  text
  csv
  json
  pdf
  image
  eml
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.Citext
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         Role
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  sessions          Session[]
  authoredScenarios Scenario[] @relation("ScenarioAuthor")
  attempts          Attempt[]

  @@map("users")
}

// Sessions store only a SHA-256 hash of the token. The raw token is
// returned to the client once at login and never persisted.
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ip        String?
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Scenario {
  id               String         @id @default(uuid()) @db.Uuid
  slug             String         @unique @db.VarChar(120)
  title            String         @db.VarChar(200)
  summary          String         @db.VarChar(1000)
  skillAreas       SkillArea[]    @map("skill_areas")
  // 1..5; enforced by a DB CHECK constraint (`scenarios_difficulty_range`,
  // see the init_scenarios migration) and mirrored by the Zod Difficulty
  // schema in @ci-train/contracts.
  difficulty       Int
  estimatedMinutes Int?           @map("estimated_minutes")
  authorUserId     String?        @map("author_user_id") @db.Uuid
  version          Int            @default(1)
  status           ScenarioStatus @default(draft)
  source           ScenarioSource @default(authored)
  importedPackHash String?        @map("imported_pack_hash")
  tags             String[]       @default([])
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  brief     ScenarioBrief?
  artifacts Artifact[]
  questions Question[]
  attempts  Attempt[]
  author    User?          @relation("ScenarioAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([skillAreas], type: Gin)
  @@index([tags], type: Gin)
  @@map("scenarios")
}

// 1-to-1 with Scenario. Held out of the scenarios table so list
// endpoints stay light — the brief body can be many KB of markdown.
model ScenarioBrief {
  id           String  @id @default(uuid()) @db.Uuid
  scenarioId   String  @unique @map("scenario_id") @db.Uuid
  markdownBody String  @map("markdown_body")
  // Populated for awareness-only skill areas (e.g. rf_awareness). The
  // UI renders this above the brief and above the debrief.
  disclaimerMd String? @map("disclaimer_md")

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("scenario_briefs")
}

// Artifact records are metadata only; bytes live in the storage backend
// at `relativePath`. The storage path is *never* derived from user input
// — it is set by the seed/import paths and only read by validated UUID
// lookup. Defense-in-depth: the storage layer also rejects paths that
// resolve outside the configured root.
model Artifact {
  id           String       @id @default(uuid()) @db.Uuid
  scenarioId   String       @map("scenario_id") @db.Uuid
  ordinal      Int          // display order within the scenario workspace
  displayName  String       @map("display_name") @db.VarChar(200)
  kind         ArtifactKind
  relativePath String       @map("relative_path") @db.VarChar(400)
  sha256       String       @db.Char(64)
  sizeBytes    Int          @map("size_bytes")
  mimeType     String       @map("mime_type") @db.VarChar(120)
  viewerHint   String?      @map("viewer_hint") @db.VarChar(60)
  createdAt    DateTime     @default(now()) @map("created_at")

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, ordinal])
  @@index([scenarioId])
  @@map("artifacts")
}

// Keep in sync with QuestionType in packages/contracts/src/questions.ts.
enum QuestionType {
  multi_choice
  short_answer
  long_answer
  confidence
}

enum AutoScoreOutcome {
  correct
  incorrect
  partial
  in_range
  out_of_range
  ungradable
}

// Authored question. `optionsJson` carries the type-specific payload:
// for multi_choice that's { options:[{id,label}], allowMultiple }; for
// other types it's `null`. Correctness lives ONLY on the AnswerKey row
// so a leaked Question record can't expose the expected answer.
model Question {
  id          String       @id @default(uuid()) @db.Uuid
  scenarioId  String       @map("scenario_id") @db.Uuid
  ordinal     Int
  type        QuestionType
  promptMd    String       @map("prompt_md")
  optionsJson Json?        @map("options_json")
  weight      Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  scenario  Scenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  answerKey AnswerKey?
  answers   AttemptAnswer[]

  @@unique([scenarioId, ordinal])
  @@index([scenarioId])
  @@map("questions")
}

// 1:1 with Question. `expectedJson` is intentionally separate so that
// the trainee-facing endpoints never select against it. `debriefMd`
// joins back only at the debrief endpoint.
model AnswerKey {
  id           String @id @default(uuid()) @db.Uuid
  questionId   String @unique @map("question_id") @db.Uuid
  expectedJson Json   @map("expected_json")
  debriefMd    String @map("debrief_md")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answer_keys")
}

model Attempt {
  id            String   @id @default(uuid()) @db.Uuid
  scenarioId    String   @map("scenario_id") @db.Uuid
  traineeUserId String   @map("trainee_user_id") @db.Uuid
  startedAt     DateTime @default(now()) @map("started_at")
  submittedAt   DateTime? @map("submitted_at")
  locked        Boolean  @default(false)
  totalScore    Float?   @map("total_score")
  maxScore      Float    @map("max_score")

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  trainee  User     @relation(fields: [traineeUserId], references: [id], onDelete: Cascade)
  answers  AttemptAnswer[]

  // One attempt per (scenario, trainee) in M5. Re-attempts get a UX
  // and a separate row in a later milestone.
  @@unique([scenarioId, traineeUserId])
  @@index([traineeUserId])
  @@map("attempts")
}

model AttemptAnswer {
  id                String   @id @default(uuid()) @db.Uuid
  attemptId         String   @map("attempt_id") @db.Uuid
  questionId        String   @map("question_id") @db.Uuid
  responseJson      Json?    @map("response_json")
  autoScore         Float?   @map("auto_score")
  autoOutcome       AutoScoreOutcome? @map("auto_outcome")
  manualScore       Float?   @map("manual_score")
  instructorNotesMd String?  @map("instructor_notes_md")
  updatedAt         DateTime @updatedAt @map("updated_at")

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("attempt_answers")
}
