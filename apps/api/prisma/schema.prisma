// M1 schema: users + sessions.
// M2 schema: + scenarios, scenario_briefs.
// M3+ will add artifacts, questions, attempts, etc.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// M12: renamed from {instructor, trainee} to align with the M7
// challenge-lab framing. UI already said admin/user; internals now
// agree.
enum Role {
  admin
  user
}

// Keep in sync with SkillArea in packages/contracts/src/scenarios.ts.
enum SkillArea {
  email_headers
  bec
  df_artifacts
  removable_media
  windows_artifacts
  network_logs
  account_compromise
  rf_awareness
  report_writing
  inference_discipline
}

enum ScenarioStatus {
  draft
  published
  archived
}

enum ScenarioSource {
  authored
  imported
}

// M21b admin review verdict. The default `needs_review` means
// "no admin has playtested this yet"; the operator promotes a
// scenario to `approved` once they've walked through it and
// confirmed the content, questions, and debriefs hold up. The
// other values are diagnostic categories so the reviewer can
// flag what's wrong without writing prose every time — details
// go in the free-text reviewNotes column. None of these values
// are user-visible: drafts vs published is the visibility gate
// (ScenarioStatus), reviewStatus is purely an internal
// operations signal.
enum ScenarioReviewStatus {
  needs_review
  approved
  needs_rewrite
  too_generic
  unclear_question
  answer_key_issue
  debrief_issue
  retire_candidate
}

// Keep in sync with ArtifactKind in packages/contracts/src/scenarios.ts.
enum ArtifactKind {
  text
  csv
  json
  pdf
  image
  eml
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.Citext
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         Role
  disabled     Boolean  @default(false)
  // M17: self-registration with admin approval.
  //
  //   approvedAt == null            → pending approval; sign-in refused
  //   approvedAt != null + disabled → admin-approved then deactivated
  //   approvedAt != null + active   → normal user
  //
  // Seeded + admin-created accounts are auto-approved (set at
  // create time). Self-registered accounts land with
  // approvedAt = null; an admin promotes them via
  // /admin/users/:id/approve.
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  sessions          Session[]
  authoredScenarios Scenario[]         @relation("ScenarioAuthor")
  reviewedScenarios Scenario[]         @relation("ScenarioReviewer")
  progress          ScenarioProgress[]

  @@map("users")
}

// Sessions store only a SHA-256 hash of the token. The raw token is
// returned to the client once at login and never persisted.
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ip        String?
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Scenario {
  id               String         @id @default(uuid()) @db.Uuid
  slug             String         @unique @db.VarChar(120)
  title            String         @db.VarChar(200)
  summary          String         @db.VarChar(1000)
  skillAreas       SkillArea[]    @map("skill_areas")
  // 1..5; enforced by a DB CHECK constraint (`scenarios_difficulty_range`,
  // see the init_scenarios migration) and mirrored by the Zod Difficulty
  // schema in @ci-train/contracts.
  difficulty       Int
  estimatedMinutes Int?           @map("estimated_minutes")
  authorUserId     String?        @map("author_user_id") @db.Uuid
  version          Int            @default(1)
  status           ScenarioStatus @default(draft)
  source           ScenarioSource @default(authored)
  importedPackHash String?        @map("imported_pack_hash")
  tags             String[]       @default([])
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // M21b admin review workflow. reviewStatus is the diagnostic
  // verdict, reviewNotes the free-text detail, reviewedAt the
  // most recent verdict timestamp, reviewedByUserId the admin
  // who set it. None of these are exposed to regular users; the
  // /admin/review surface reads them, the regular /scenarios
  // detail does not.
  reviewStatus       ScenarioReviewStatus @default(needs_review) @map("review_status")
  reviewNotes        String?              @map("review_notes")
  reviewedAt         DateTime?            @map("reviewed_at")
  reviewedByUserId   String?              @map("reviewed_by_user_id") @db.Uuid

  brief         ScenarioBrief?
  artifacts     Artifact[]
  questions     Question[]
  progress      ScenarioProgress[]
  indicatorSets IndicatorSet[]
  author        User?              @relation("ScenarioAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  reviewer      User?              @relation("ScenarioReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([reviewStatus])
  @@index([skillAreas], type: Gin)
  @@index([tags], type: Gin)
  @@map("scenarios")
}

// 1-to-1 with Scenario. Held out of the scenarios table so list
// endpoints stay light — the brief body can be many KB of markdown.
model ScenarioBrief {
  id           String  @id @default(uuid()) @db.Uuid
  scenarioId   String  @unique @map("scenario_id") @db.Uuid
  markdownBody String  @map("markdown_body")
  // Populated for awareness-only skill areas (e.g. rf_awareness). The
  // UI renders this above the brief and above the debrief.
  disclaimerMd String? @map("disclaimer_md")

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("scenario_briefs")
}

// Artifact records are metadata only; bytes live in the storage backend
// at `relativePath`. The storage path is *never* derived from user input
// — it is set by the seed/import paths and only read by validated UUID
// lookup. Defense-in-depth: the storage layer also rejects paths that
// resolve outside the configured root.
model Artifact {
  id           String       @id @default(uuid()) @db.Uuid
  scenarioId   String       @map("scenario_id") @db.Uuid
  ordinal      Int          // display order within the scenario workspace
  displayName  String       @map("display_name") @db.VarChar(200)
  kind         ArtifactKind
  relativePath String       @map("relative_path") @db.VarChar(400)
  sha256       String       @db.Char(64)
  sizeBytes    Int          @map("size_bytes")
  mimeType     String       @map("mime_type") @db.VarChar(120)
  viewerHint   String?      @map("viewer_hint") @db.VarChar(60)
  createdAt    DateTime     @default(now()) @map("created_at")

  scenario             Scenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  // M6: indicator sets that point at this artifact for their source.
  // ON DELETE SET NULL so deleting an artifact doesn't take the
  // indicator set down — the items_json content survives.
  sourcedIndicatorSets IndicatorSet[]

  @@unique([scenarioId, ordinal])
  @@index([scenarioId])
  @@map("artifacts")
}

// Keep in sync with QuestionType in packages/contracts/src/questions.ts.
//
// M7 dropped narrative grading; M8 removed `short_answer` / `long_answer`
// from the Postgres enum entirely (recreate-the-type migration). The
// four values below are the only ones the API + UI know how to render
// or grade.
enum QuestionType {
  multi_choice
  confidence
  select_indicators
  text_match
}

// Authored question. `optionsJson` carries the type-specific payload:
// for multi_choice that's { options:[{id,label}], allowMultiple }; for
// other types it's `null`. Correctness lives ONLY on the AnswerKey row
// so a leaked Question record can't expose the expected answer.
model Question {
  id              String       @id @default(uuid()) @db.Uuid
  scenarioId      String       @map("scenario_id") @db.Uuid
  ordinal         Int
  type            QuestionType
  promptMd        String       @map("prompt_md")
  optionsJson     Json?        @map("options_json")
  // M6: nullable FK to indicator_sets. Required for select_indicators
  // questions and forbidden for other types — enforced by a CHECK
  // constraint in the migration.
  indicatorSetId  String?      @map("indicator_set_id") @db.Uuid
  weight          Int          @default(1)
  // M21b: per-question free-text review notes. Same admin-only
  // visibility rules as scenario.reviewNotes. Pair with a
  // scenario-level reviewStatus to record granular issues
  // ("Q3 prompt phrasing is ambiguous") without losing the
  // top-level verdict.
  reviewNotes     String?      @map("review_notes")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  scenario     Scenario           @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  indicatorSet IndicatorSet?      @relation(fields: [indicatorSetId], references: [id], onDelete: Restrict)
  answerKey    AnswerKey?
  responses    QuestionResponse[]

  @@unique([scenarioId, ordinal])
  @@index([scenarioId])
  @@index([indicatorSetId])
  @@map("questions")
}

// M6: indicator sets. Authored independently of questions so the same
// set can back multiple questions (e.g. "which support BEC?" and
// "which overclaim?"). Items are stored as JSONB; correctness is NOT
// here — it lives in AnswerKey.expectedJson, same isolation as MC.
model IndicatorSet {
  id               String   @id @default(uuid()) @db.Uuid
  scenarioId       String   @map("scenario_id") @db.Uuid
  slug             String   @db.VarChar(120)
  displayName      String   @map("display_name") @db.VarChar(120)
  sourceArtifactId String?  @map("source_artifact_id") @db.Uuid
  itemsJson        Json     @map("items_json")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  scenario       Scenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  sourceArtifact Artifact?  @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  questions      Question[]

  @@unique([scenarioId, slug])
  @@index([scenarioId])
  @@map("indicator_sets")
}

// 1:1 with Question. `expectedJson` is intentionally separate so that
// the trainee-facing endpoints never select against it. `debriefMd`
// joins back only at the debrief endpoint.
model AnswerKey {
  id           String @id @default(uuid()) @db.Uuid
  questionId   String @unique @map("question_id") @db.Uuid
  expectedJson Json   @map("expected_json")
  debriefMd    String @map("debrief_md")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answer_keys")
}

// M7 challenge-mode: one row per (user, scenario). Tracks aggregate
// completion only. Replaces the M5 Attempt model. Column renamed
// from trainee_user_id → user_id in M12.
model ScenarioProgress {
  id                 String    @id @default(uuid()) @db.Uuid
  scenarioId         String    @map("scenario_id") @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  startedAt          DateTime  @default(now()) @map("started_at")
  // Set when all questions in the scenario have a non-null completedAt
  // on their corresponding QuestionResponse row. Cleared if questions
  // are added to the scenario after completion (defensive against
  // authoring drift; pack import is the trigger).
  completedAt        DateTime? @map("completed_at")
  // Denormalized counters so the trainee workspace can render
  // progress without per-row aggregation. Recomputed in the same
  // transaction as any question completion.
  completedQuestions Int       @default(0) @map("completed_questions")
  totalQuestions     Int       @map("total_questions")

  scenario  Scenario           @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses QuestionResponse[]

  @@unique([scenarioId, userId])
  @@index([userId])
  @@map("scenario_progress")
}

// M7 challenge-mode: one row per (progress, question). Stores the
// trainee's latest submitted response, completion timestamp (set on
// the first correct answer), and how many times they've tried.
// Replaces the M5 AttemptAnswer model.
model QuestionResponse {
  id           String    @id @default(uuid()) @db.Uuid
  progressId   String    @map("progress_id") @db.Uuid
  questionId   String    @map("question_id") @db.Uuid
  // Latest submitted response (for widget rehydration). Persisted on
  // every submit, including incorrect ones.
  responseJson Json?     @map("response_json")
  // Set the first time the trainee submitted a correct answer. Never
  // cleared — re-grading does not "uncomplete" a question.
  completedAt  DateTime? @map("completed_at")
  // Total submissions to date. Used by the UI to "got it on try N"
  // and to trigger authored hints (text_match.hintAfterTries).
  attemptCount Int       @default(0) @map("attempt_count")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  progress ScenarioProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  question Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([progressId, questionId])
  @@index([progressId])
  @@map("question_responses")
}
