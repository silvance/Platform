# ─────────────────────────────────────────────────────────────
# ci-train environment configuration
# Copy to .env for `docker compose up`. Per-app .env.local files
# are used when running outside Docker (pnpm dev).
# ─────────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=citrain
POSTGRES_PASSWORD=citrain_dev_password_change_me
POSTGRES_DB=citrain

# API (NestJS)
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
# DATABASE_URL is composed inside docker-compose; for host-local dev set it explicitly:
# DATABASE_URL=postgres://citrain:citrain_dev_password_change_me@localhost:5432/citrain

# Web (Next.js)
WEB_PORT=3000
# Server-side URL the Next.js server uses to reach the API.
# In docker compose this points at the api service. For host-local dev override to http://localhost:4000
API_INTERNAL_URL=http://api:4000
