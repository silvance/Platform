# ─────────────────────────────────────────────────────────────
# ci-train — local-mode env file.
#
# Use for:
#   • single-developer laptop ("Local-only" mode), OR
#   • LAN beta on a dedicated local machine.
#
# Usage:
#   cp deploy/env/local.env.example deploy/env/local.env
#   $EDITOR deploy/env/local.env       # change passwords / bind hosts
#   docker compose --env-file deploy/env/local.env \
#                  -f deploy/docker-compose.local.yml up --build
#
# DO NOT commit deploy/env/local.env — only this *.example.
# ─────────────────────────────────────────────────────────────

# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=citrain
# CHANGE THIS even for local — same machine + same password across
# environments is how dev creds leak. `openssl rand -base64 32`.
POSTGRES_PASSWORD=citrain_dev_password_change_me
POSTGRES_DB=citrain

# ─── Runtime ──────────────────────────────────────────────────
# "development" → verbose Prisma logs + Web cookie's Secure flag off
# so http://localhost works. Flip to "production" only on a real LAN
# beta that's terminating TLS (see deploy/Caddyfile.example).
NODE_ENV=development

# ─── Ports ────────────────────────────────────────────────────
# Where the host binds the api and web containers' published ports.
#   0.0.0.0  → reachable from anything that can route to this machine
#               (use for LAN beta)
#   127.0.0.1 → loopback only (use for solo development)
API_BIND_HOST=0.0.0.0
WEB_BIND_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000

# Web → api URL **inside the Docker network**. Override only if you
# split the stacks across hosts (unusual at local scale).
API_INTERNAL_URL=http://api:4000

# ─── Reverse-proxy trust ──────────────────────────────────────
# OFF for local-mode. Login is rate-limited by req.ip; turning this
# on without a real, sanitizing proxy in front lets spoofed
# X-Forwarded-For headers rotate identity per request.
TRUST_PROXY=false

# ─── BFF → API forwarded-IP channel ───────────────────────────
# Shared secret used by the web BFF to attach a trusted
# X-CI-Train-Client-IP header on outbound API calls so the API
# rate-limits browser-driven traffic by real-client IP instead of
# the BFF container's IP. Leave UNSET in local-mode (single user,
# no spoofing risk) — the throttler safely falls back to req.ip.
# In any deployment with multiple users the SAME secret must be
# set on both the api and web services to ≥16 unguessable random
# bytes, e.g.:
#   openssl rand -hex 32
# deploy/Caddyfile.example shows how to scrub the matching inbound
# X-CI-Train-* headers so public clients can't spoof them.
# BFF_FORWARD_SECRET=

# ─── Seed accounts ────────────────────────────────────────────
# The seed creates one admin and one regular user. M15 made the
# passwords env-driven; if you leave SEED_*_PASSWORD unset, the seed
# generates a random password on first run and prints it once to the
# container log. For repeatable local-dev — and ALWAYS for shared /
# remote deploys — set explicit passwords here.
#
# Re-running the seed is idempotent:
#   - SEED_*_PASSWORD set → password is rotated to that value.
#   - SEED_*_PASSWORD unset and account already exists → the
#     existing password is NOT touched (so a password you changed
#     through the UI or the reset-password CLI sticks).
#
# Recovery (if you forget):
#   docker compose exec api node dist/scripts/reset-password.js \
#     --email instructor@example.local --password 'NewPasswordHere'
SEED_ADMIN_EMAIL=instructor@example.local
SEED_USER_EMAIL=trainee@example.local
# SEED_ADMIN_PASSWORD=change-me-min-10-chars
# SEED_USER_PASSWORD=change-me-min-10-chars

# Backwards-compat aliases (pre-M15 env-file). Still honored — if
# both new and old names are set, the new ones win. Safe to delete
# from a freshly-edited env file.
# SEED_INSTRUCTOR_EMAIL=instructor@example.local
# SEED_TRAINEE_EMAIL=trainee@example.local
