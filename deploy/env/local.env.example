# ─────────────────────────────────────────────────────────────
# ci-train — local-mode env file.
#
# Use for:
#   • single-developer laptop ("Local-only" mode), OR
#   • LAN beta on a dedicated local machine.
#
# Usage:
#   cp deploy/env/local.env.example deploy/env/local.env
#   $EDITOR deploy/env/local.env       # change passwords / bind hosts
#   docker compose --env-file deploy/env/local.env \
#                  -f deploy/docker-compose.local.yml up --build
#
# DO NOT commit deploy/env/local.env — only this *.example.
# ─────────────────────────────────────────────────────────────

# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=citrain
# CHANGE THIS even for local — same machine + same password across
# environments is how dev creds leak. `openssl rand -base64 32`.
POSTGRES_PASSWORD=citrain_dev_password_change_me
POSTGRES_DB=citrain

# ─── Runtime ──────────────────────────────────────────────────
# "development" → verbose Prisma logs + Web cookie's Secure flag off
# so http://localhost works. Flip to "production" only on a real LAN
# beta that's terminating TLS (see deploy/Caddyfile.example).
NODE_ENV=development

# ─── Ports ────────────────────────────────────────────────────
# Where the host binds the api and web containers' published ports.
#   0.0.0.0  → reachable from anything that can route to this machine
#               (use for LAN beta)
#   127.0.0.1 → loopback only (use for solo development)
API_BIND_HOST=0.0.0.0
WEB_BIND_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000

# Web → api URL **inside the Docker network**. Override only if you
# split the stacks across hosts (unusual at local scale).
API_INTERNAL_URL=http://api:4000

# ─── Reverse-proxy trust ──────────────────────────────────────
# OFF for local-mode. Login is rate-limited by req.ip; turning this
# on without a real, sanitizing proxy in front lets spoofed
# X-Forwarded-For headers rotate identity per request.
TRUST_PROXY=false

# ─── Seed accounts ────────────────────────────────────────────
# Emails for the bootstrap instructor + trainee. Passwords are
# randomly generated and printed by the seed.
SEED_INSTRUCTOR_EMAIL=instructor@example.local
SEED_TRAINEE_EMAIL=trainee@example.local
