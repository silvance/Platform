# ─────────────────────────────────────────────────────────────
# ci-train — VPS-mode env file.
#
# Use on the single-node VPS that fronts api.cicyberlab.com.
# The Next.js frontend deploys to Vercel separately — see
# deploy/env/vercel.env.example.
#
# Usage on the VPS:
#   cp deploy/env/vps.env.example deploy/env/vps.env
#   $EDITOR deploy/env/vps.env       # fill in the real password
#   chmod 600 deploy/env/vps.env
#   docker compose --env-file deploy/env/vps.env \
#                  -f deploy/docker-compose.vps.yml \
#                  up -d --build
#
# DO NOT commit deploy/env/vps.env — only this *.example.
# ─────────────────────────────────────────────────────────────

# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=citrain
# Generate with `openssl rand -base64 32`. Long. Random. Unique.
# This is effectively the database root password.
POSTGRES_PASSWORD=replace-with-long-random-secret
POSTGRES_DB=citrain

# ─── Reverse-proxy trust ──────────────────────────────────────
# Caddy is the one hop in front. Setting this to "0" makes the login
# throttler key on Caddy's loopback IP (all logins share a bucket).
# Setting it to "true" (all hops) lets any client spoof
# X-Forwarded-For and rotate identity per request. "1" is the right
# answer for Caddy or nginx with the headers documented in
# deploy/Caddyfile.example.
TRUST_PROXY=1

# ─── BFF → API forwarded-IP channel ───────────────────────────
# REQUIRED on the VPS. The web BFF stamps X-CI-Train-Client-IP +
# X-CI-Train-BFF-Secret on outbound API calls so the API rate-
# limits browser-driven traffic by the real client IP instead of
# the BFF container's loopback IP. Without this secret, all
# browser logins share one throttle bucket regardless of who
# they came from.
#
# Generate a fresh value (≥16 unguessable random bytes) and use
# the SAME string for both the api and web services:
#   openssl rand -hex 32
#
# Caddy MUST strip any inbound X-CI-Train-* headers from public
# clients so they can't spoof this — see deploy/Caddyfile.example
# for the `header_down -X-CI-Train-*` snippet.
BFF_FORWARD_SECRET=change_me_to_a_fresh_openssl_rand_hex_32_value

# ─── Host paths ───────────────────────────────────────────────
# Where Postgres data, artifacts, and backups live on the VPS.
# Bind-mounted into the containers by docker-compose.vps.yml.
CITRAIN_DATA_ROOT=/var/lib/citrain

# ─── Seed accounts ────────────────────────────────────────────
# Emails for the bootstrap instructor + trainee. Passwords are
# randomly generated and printed once by the seed.
SEED_INSTRUCTOR_EMAIL=instructor@cicyberlab.com
SEED_TRAINEE_EMAIL=trainee@cicyberlab.com
