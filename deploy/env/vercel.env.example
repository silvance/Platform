# ─────────────────────────────────────────────────────────────
# ci-train — Vercel project environment.
#
# These are the env vars to set in the Vercel dashboard for the
# apps/web project. NOT loaded by docker compose — this file
# exists as a checklist + reference for the Vercel UI.
#
# Set each variable in: Project → Settings → Environment Variables.
# Apply to all environments (Production, Preview, Development) unless
# noted otherwise.
# ─────────────────────────────────────────────────────────────

# Where Next.js server components reach the API. MUST be the
# public API URL — Vercel's serverless functions cannot reach a
# private docker network on the VPS.
API_INTERNAL_URL=https://api.cicyberlab.com

# Standard Next.js production marker. Enables Secure cookie flag,
# disables verbose error pages.
NODE_ENV=production

# Disable Next.js telemetry uploads.
NEXT_TELEMETRY_DISABLED=1

# ─── Vercel project config (not env vars; set in Project Settings) ──
#
# Root Directory:    apps/web
# Framework Preset:  Next.js (auto-detect)
# Install command:   pnpm install --frozen-lockfile
# Build command:     pnpm --filter @ci-train/contracts build && pnpm --filter @ci-train/web build
# Output Directory:  (leave as default, .next)
#
# Domains:
#   cicyberlab.com         (production)
#   www.cicyberlab.com     (redirect to cicyberlab.com)
#
# Important:
#   There is currently a *second* Vercel project named "platform-api"
#   that tries to build NestJS on every PR and fails. **Disconnect
#   it** once the VPS API is serving traffic — NestJS is not a Vercel
#   runtime. Vercel dashboard → platform-api → Settings → Remove
#   Project.
