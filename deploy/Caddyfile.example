# Example Caddyfile for ci-train.
#
# Three usage modes:
#
#   1. Local-only (single laptop)
#      You do not need Caddy. `docker compose -f
#      deploy/docker-compose.local.yml up` exposes the web app on
#      http://localhost:3000 directly.
#
#   2. LAN beta (dedicated local machine)
#      Caddy is optional but useful — set up a domain on your LAN
#      DNS (e.g. citrain.lan) and copy the api.cicyberlab.com block
#      below, replacing the hostname. Use the `tls internal` directive
#      (commented below) to get a self-signed cert for LAN HTTPS.
#
#   3. Public VPS
#      Required. The VPS deployment binds the API to 127.0.0.1:4000;
#      Caddy is the only thing the public internet can reach. Use the
#      block as-is, just change the hostname.
#
# Install:
#   apt install caddy
#   cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   $EDITOR /etc/caddy/Caddyfile
#   caddy validate --config /etc/caddy/Caddyfile
#   systemctl reload caddy
#
# Let's Encrypt is fetched automatically on the first request to the
# public hostname. DNS must already point at this host and 80 + 443
# must be open.

api.cicyberlab.com {
    encode zstd gzip

    # For LAN-beta mode, uncomment the next line and remove the
    # `api.cicyberlab.com` hostname (replace with citrain.lan).
    # tls internal

    reverse_proxy 127.0.0.1:4000 {
        header_up Host              {host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For   {remote_host}
    }

    # Belt-and-braces security headers. The API also sets stricter
    # headers on artifact responses (CSP with sandbox, nosniff); those
    # are not overridden here.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
    }

    log {
        output file /var/log/caddy/api.access.log
        format json
    }
}
